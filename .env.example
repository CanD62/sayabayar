# ════════════════════════════════════════════════════════════════
#  TEMPLATE ENVIRONMENT — Salin file ini menjadi .env
#  Jangan mengisi nilai sensitif di file ini!
#  Commit file ini ke Git sebagai panduan untuk developer lain.
# ════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────
# LOCAL  : mysql://root:password@localhost:3306/payment_gateway
# SERVER : mysql://payment_gateway:password@vpn.pcs.my.id:1212/payment_gateway?timezone=%2B07:00
DATABASE_URL=

# ── Redis ─────────────────────────────────────────────────────
# LOCAL  : redis://localhost:6379
# SERVER : redis://:password@vpn.pcs.my.id:6363
REDIS_URL=

# ── Auth ─────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=900
JWT_REFRESH_EXPIRES_IN=604800

# ── Enkripsi ──────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ── App URL ──────────────────────────────────────────────────
# LOCAL  : http://localhost:3001 / http://localhost:3000
# SERVER : https://api.sayabayar.com / https://sayabayar.com
API_URL=
FRONTEND_URL=
API_PORT=3001

# ── Google OAuth ─────────────────────────────────────────────
# Daftar di: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Scraper ──────────────────────────────────────────────────
MAX_BROWSERS=20
SCRAPER_CONCURRENCY=10

# ── Admin ────────────────────────────────────────────────────
ADMIN_EMAIL=

# ── SMTP / Email ─────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── Cloudflare Turnstile ──────────────────────────────────────
# LOCAL  : kosongkan kedua key ini (Turnstile akan di-bypass)
# SERVER : isi dengan key dari Cloudflare Dashboard
NEXT_PUBLIC_CF_TURNSTILE_SITE_KEY=
CF_TURNSTILE_SECRET_KEY=
