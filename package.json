{
  "name": "payment-gateway",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel --filter api --filter scraper --filter frontend dev",
    "dev:api": "pnpm --filter api dev",
    "dev:scraper": "pnpm --filter scraper dev",
    "dev:frontend": "pnpm --filter frontend dev",
    "build": "pnpm --filter './apps/*' build",
    "lint": "pnpm --filter './apps/*' lint",
    "db:generate": "pnpm --filter @payment-gateway/shared prisma:generate",
    "db:migrate": "pnpm --filter @payment-gateway/shared prisma:migrate",
    "db:push": "pnpm --filter @payment-gateway/shared prisma:push",
    "db:studio": "pnpm --filter @payment-gateway/shared prisma:studio"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "prisma",
      "@prisma/client",
      "@prisma/engines",
      "bcrypt",
      "playwright"
    ]
  }
}